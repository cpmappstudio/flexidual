# Convex Configuration
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://verb-noun-00.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://verb-noun-00.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Optional: Additional environment variables
# NODE_ENV=development
# DATABASE_URL=your_database_url_if_needed
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# LiveKit Server URL (Used Client-Side)
NEXT_PUBLIC_LIVEKIT_URL=<Your LiveKit Server URL>
# LiveKit Credentials (Used Server-Side via Convex)
LIVEKIT_API_KEY=<Your LiveKit API Key>
LIVEKIT_API_SECRET=<Your LiveKit API Secret>

# School and Campus Ids for data migration and testing
SCHOOL_ID=xxxxxxxxxxxxxxxxxxxx
CAMPUS_ID=xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# S3 RECORDING STORAGE (LiveKit Egress)
# Tested with Cloudflare R2 (S3 Compatible)
# -----------------------------------------------------------------------------
# The name of the bucket you created
S3_BUCKET="flexidual-recordings-dev"

# The region of your bucket (For Cloudflare R2, this is usually 'auto' or 'us-east-1')
S3_REGION="auto"

# Your generated Access Key ID
S3_ACCESS_KEY="your_s3_access_key"

# Your generated Secret Access Key
S3_SECRET_KEY="your_s3_secret_key"

# ONLY REQUIRED FOR S3-COMPATIBLE SERVICES (e.g., Cloudflare R2, MinIO, DigitalOcean Spaces)
# If using actual AWS S3, leave this blank or comment it out.
# For R2, it looks like: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"